    <title>XML文件或者字符串转Bean对象</title>
    <link href="https://jiang-shijie826.github.io/2023/03/20/XML%E6%96%87%E4%BB%B6%E6%88%96%E8%80%85%E5%AD%97%E7%AC%A6%E4%B8%B2%E8%BD%ACBean%E5%AF%B9%E8%B1%A1/"/>
    <id>https://jiang-shijie826.github.io/2023/03/20/XML%E6%96%87%E4%BB%B6%E6%88%96%E8%80%85%E5%AD%97%E7%AC%A6%E4%B8%B2%E8%BD%ACBean%E5%AF%B9%E8%B1%A1/</id>
